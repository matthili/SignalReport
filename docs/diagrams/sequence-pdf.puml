@startuml sequence-pdf
!pragma layout smetana
skinparam dpi 150
scale max 16384 width
!theme plain
skinparam sequenceFontSize 13
skinparam sequenceArrowThickness 1
skinparam roundcorner 10

actor Benutzer
participant Browser
participant "ExportRoutes\n(web.api)" as Export
participant PdfReportGenerator
participant Config
participant H2MeasurementRepository
database "H2 Primary" as DB
participant ReliabilityReport
participant ConnectivityAssessment
participant JFreeChart
participant OpenPDF

Benutzer -> Browser : Klicke "PDF-Bericht (24h)"
Browser -> Export : GET /api/report?hours=24
Export -> PdfReportGenerator : new PdfReportGenerator(repo)
Export -> PdfReportGenerator : generateReport(24)

PdfReportGenerator -> Config : getInstance() / getUserInfo()
Config --> PdfReportGenerator : Config + UserInfo
PdfReportGenerator -> HostIdentifier : getHostname() / getHostHash()
PdfReportGenerator -> NetworkInfo : getLocalIPv4() / getExternalIPv4()

group Statistik je Typ
  PdfReportGenerator -> H2MeasurementRepository : calculateStatistics("PING"/"DNS"/"HTTP", 24)
  H2MeasurementRepository -> DB : SELECT ... WHERE type = ? (excluded = FALSE)
  DB --> H2MeasurementRepository : Ergebnisse
  H2MeasurementRepository --> PdfReportGenerator : Statistics (avg, p95, max, loss, jitter)
end

PdfReportGenerator -> H2MeasurementRepository : findSince(since)
H2MeasurementRepository -> DB : SELECT * FROM measurements WHERE timestamp >= ...
DB --> H2MeasurementRepository : List<Measurement>
H2MeasurementRepository --> PdfReportGenerator : Messungen (inkl. PING + MAINTENANCE-Marker)

group Charts (PING/DNS/HTTP)
  PdfReportGenerator -> PdfReportGenerator : filterByType + detectTargetChanges
  PdfReportGenerator -> JFreeChart : createLatencyChart(...)
  JFreeChart --> PdfReportGenerator : BufferedImage (rote Linien bei Ziel-Änderungen)
end

PdfReportGenerator -> PdfReportGenerator : Top 10 schlechteste Messungen

group Störungs-Lokalisierung
  PdfReportGenerator -> H2MeasurementRepository : calculateStatistics("GATEWAY_NEAR"/"GATEWAY_FAR", 24)
  H2MeasurementRepository --> PdfReportGenerator : Statistics (nah/fern)
  PdfReportGenerator -> ConnectivityAssessment : assess(near, far, internet)
  ConnectivityAssessment --> PdfReportGenerator : Verdikt (Router / Internet-Gateway / Internet)
end

group Verfügbarkeit & Zuverlässigkeit
  PdfReportGenerator -> ReliabilityReport : compute(pingMessungen, interval, fenster, maintenanceSamples)
  ReliabilityReport --> PdfReportGenerator : uptime, coverage, MTBF, MTTR + aggregierte Ausfälle
end

group PDF-Dokument
  PdfReportGenerator -> OpenPDF : new Document(A4) + Kopf (Kunde, Host, IPs)
  PdfReportGenerator -> OpenPDF : Statistik-Blöcke (PING/DNS/HTTP) + Charts
  PdfReportGenerator -> OpenPDF : Top 10 schlechteste Messungen (Tabelle)
  PdfReportGenerator -> OpenPDF : Störungs-Lokalisierung (Verdikt + Segmente)
  PdfReportGenerator -> OpenPDF : Verfügbarkeit & Zuverlässigkeit (Kennzahlen)
  PdfReportGenerator -> OpenPDF : Verbindungsausfälle (aggregiert, längste zuerst)
  OpenPDF --> PdfReportGenerator : PDF-Bytes
end

PdfReportGenerator --> Export : byte[] pdfBytes
Export -> Browser : HTTP 200 + Content-Disposition: attachment
Browser -> Benutzer : Speichere PDF-Datei

note over PdfReportGenerator, OpenPDF
  PDF enthält: Kunden-/Host-Daten, 3 Charts (PING/DNS/HTTP)
  mit Ziel-Änderungs-Markierung, Top 10 schlechteste Messungen,
  Störungs-Lokalisierung (ConnectivityAssessment),
  Verfügbarkeit & Zuverlässigkeit (ReliabilityReport:
  uptime/coverage/MTBF/MTTR) und die aggregierte
  Ausfallliste. DejaVu-Schrift fuer Unicode eingebettet.
end note

note right of DB
  Lese-Operationen gehen immer auf die Primary-DB.
  Aus der Wertung ausgeschlossene Messungen
  (Spalte excluded) fliessen nicht in die Kennzahlen ein.
end note
@enduml
