@startuml SignalReport - Klassen-Diagramm
!theme plain
skinparam classFontSize 13
skinparam packageStyle rectangle
skinparam linetype ortho

package "measurement" {
  interface Measurer <<interface>> {
    +Measurement measure(String target)
  }

  class PingMeasurer {
    +Measurement measure(String target)
  }

  class DnsMeasurer {
    +Measurement measure(String hostname)
  }

  class HttpMeasurer {
    -HttpClient client
    +Measurement measure(String url)
  }

  class DnsBenchmark {
    -List<DnsServer> dnsServers
    -String hostname
    -int timeoutMs
    +List<DnsResult> benchmark()
    -DnsResult measureDnsServer(DnsServer server)
  }
}

package "model" {
  class Measurement {
    -Instant timestamp
    -String target
    -double latencyMs
    -boolean success
    -String type
    -String localIPv4
    -String localIPv6
    -String externalIPv4
    -String externalIPv6
    -String hostHash
    +Instant getTimestamp()
    +String getTarget()
    +double getLatencyMs()
    +boolean isSuccess()
    +String getType()
    +String getHostHash()
  }
}

package "persistence" {
  class H2MeasurementRepository {
    -String jdbcUrl
    -Connection connection
    +void save(Measurement m)
    +List<Measurement> findLastN(int n)
    +List<Measurement> findSince(Instant since)
    +List<Measurement> findAll()
    +Statistics calculateStatistics(String type, int hours)
    +List<HourlyAverage> calculateHourlyAverages(String type, int days)
    +void trackIpChange(String currentIp, String hostHash)
    +List<IpChange> getIpChanges(int limit)
    +List<IpChangeStats> getIpChangeStatistics()
    +void registerHost(String hostHash, String hostname, String os)
    +List<HostInfo> getAllHosts()
  }

  class "H2MeasurementRepository.Statistics" as RepoStats {
    -double avgLatency
    -double p95Latency
    -double maxLatency
    -double packetLossPercent
    -double jitter
  }

  class "H2MeasurementRepository.HourlyAverage" as RepoHourlyAvg {
    -int hourOfDay
    -double avgLatency
    -int count
  }

  class "H2MeasurementRepository.HostInfo" as RepoHostInfo {
    -String hostHash
    -String hostname
    -String operatingSystem
    -Instant firstSeen
    -Instant lastSeen
  }

  class "H2MeasurementRepository.IpChange" as RepoIpChange {
    -Instant timestamp
    -String oldIp
    -String newIp
    -String changeType
    -String hostHash
  }

  class "H2MeasurementRepository.IpChangeStats" as RepoIpChangeStats {
    -String hostHash
    -int changeCount
    -Instant firstChange
    -Instant lastChange
  }
}

package "config" {
  class Config <<Singleton>> {
    -{static} volatile Config instance
    -MeasurementConfig measurement
    -DatabaseConfig database
    -WebserverConfig webserver
    -List<DnsServer> dnsServers
    -MaintenanceWindow maintenanceWindow
    -UserInfo userInfo
    -SetupConfig setup
    -AuthConfig auth
    -ThemeConfig theme
    +{static} Config load(String path)
    +{static} void save(String path)
    +{static} Config getInstance()
    +{static} String hashPassword(String password)
  }

  class "Config.MeasurementConfig" as ConfigMeas {
    -int intervalSeconds
    -Targets targets
  }

  class "Config.Targets" as ConfigTargets {
    -String ping
    -String dns
    -String http
  }

  class "Config.MaintenanceWindow" as ConfigMaint {
    -boolean enabled
    -int startHour
    -int startMinute
    -int endHour
    -int endMinute
    +boolean isMaintenanceTime()
  }

  class "Config.UserInfo" as ConfigUser {
    -String provider
    -String customerId
    -String userName
  }

  class "Config.SetupConfig" as ConfigSetup {
    -boolean setupCompleted
    -String adminPasswordHash
    +boolean verifyAdminPassword(String pw)
  }

  class "Config.AuthConfig" as ConfigAuth {
    -boolean enabled
    -String adminPasswordHash
    -String userPasswordHash
    +boolean verifyAdminPassword(String pw)
    +boolean verifyUserPassword(String pw)
  }

  class "Config.ThemeConfig" as ConfigTheme {
    -boolean darkMode
    +boolean isDarkMode()
    +void setDarkMode(boolean darkMode)
  }

  class "Config.DnsServer" as ConfigDnsServer {
    -String name
    -String address
    -String region
    -String provider
  }
}

package "web" {
  class WebServer {
    -H2MeasurementRepository repository
    -HtmlPageRenderer htmlPageRenderer
    -SetupPageRenderer setupPageRenderer
    -Javalin app
    +void start(int port)
    +void stop()
  }

  class HtmlPageRenderer {
    +String render()
  }

  class SetupPageRenderer {
    +String render()
  }
}

package "export" {
  class PdfReportGenerator {
    -H2MeasurementRepository repository
    +byte[] generateReport(int hours)
    -BufferedImage createLatencyChart(...)
    -List<String> getTargetsChronological(...)
    -List<ConnectionOutage> detectConnectionOutages(...)
  }

  class PushNotificationService <<Singleton>> {
    -List<String> subscribedClients
    -boolean enabled
    -double latencyThreshold
    -int consecutiveBadMeasurements
    +{static} PushNotificationService getInstance()
    +void checkAndNotify(...)
  }
}

package "network" {
  class HostIdentifier {
    -{static} String cachedHash
    +{static} String getHostHash()
    +{static} String getHostname()
    +{static} String getOperatingSystem()
  }

  class NetworkInfo {
    -{static} HttpClient HTTP_CLIENT
    -{static} long CACHE_DURATION_SECONDS
    -{static} String cachedExternalIPv4
    -{static} String cachedExternalIPv6
    -{static} String cachedLocalIPv4
    -{static} String cachedLocalIPv6
    -{static} Instant cacheTimestamp
    -{static} synchronized void refreshCacheIfNeeded()
    +{static} synchronized String getLocalIPv4()
    +{static} synchronized String getExternalIPv4()
    +{static} synchronized String getLocalIPv6()
    +{static} synchronized String getExternalIPv6()
  }
}

package "main" {
  class SignalReportApp {
    {static} +void main(String[] args)
  }
}

' --- Vererbung / Interface ---
Measurer <|.. PingMeasurer
Measurer <|.. DnsMeasurer
Measurer <|.. HttpMeasurer

' --- Messung ---
PingMeasurer --> Measurement : erzeugt
DnsMeasurer --> Measurement : erzeugt
HttpMeasurer --> Measurement : erzeugt
DnsBenchmark --> ConfigDnsServer : verwendet

' --- Repository ---
H2MeasurementRepository --> RepoStats
H2MeasurementRepository --> RepoHourlyAvg
H2MeasurementRepository --> RepoHostInfo
H2MeasurementRepository --> RepoIpChange
H2MeasurementRepository --> RepoIpChangeStats

' --- Config ---
Config --> ConfigMeas
ConfigMeas --> ConfigTargets
Config --> ConfigMaint
Config --> ConfigUser
Config --> ConfigSetup
Config --> ConfigAuth
Config --> ConfigTheme
Config --> ConfigDnsServer

' --- Web ---
WebServer --> H2MeasurementRepository
WebServer --> HtmlPageRenderer : delegiert HTML-Rendering
WebServer --> SetupPageRenderer : delegiert Setup-Rendering
WebServer --> Config
HtmlPageRenderer --> Config : liest Theme
SetupPageRenderer --> Config : liest Theme

' --- Export ---
PdfReportGenerator --> H2MeasurementRepository
PdfReportGenerator --> Measurement

' --- Main ---
SignalReportApp --> PingMeasurer
SignalReportApp --> DnsMeasurer
SignalReportApp --> HttpMeasurer
SignalReportApp --> H2MeasurementRepository
SignalReportApp --> WebServer
SignalReportApp --> HostIdentifier
SignalReportApp --> NetworkInfo
SignalReportApp --> Config

note top of H2MeasurementRepository
  Embedded H2-Datenbank
  Datenbank-Datei: ./data/signalreport.mv.db
  Tabellen: measurements, hosts, ip_changes
end note

note right of WebServer
  Javalin Web-Framework (Port 4567)
  REST-API + HTML-UI
  HTML-Rendering ausgelagert in
  HtmlPageRenderer / SetupPageRenderer
end note

note right of Measurer
  Strategy-Pattern:
  Einheitliches Interface
  für alle Messtypen
end note

note bottom of Config
  Zentrale Konfigurationsverwaltung
  JSON-Persistenz (config.json)
  hashPassword() zentral dedupliziert
end note
@enduml
