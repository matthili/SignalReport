@startuml class-diagram
!pragma layout smetana
skinparam dpi 150
scale max 16384 width
!theme plain
skinparam classFontSize 13
skinparam packageStyle rectangle
skinparam linetype ortho

' ============================================================
'  at.mafue.signalreport  (Einstiegspunkt)
' ============================================================
package "signalreport" {
  class SignalReportApp {
    {static} +void main(String[] args)
    -{static} void rediscoverGatewaysAfterIpChange(Config cfg, String oldIp, String newIp)
  }
  class ServiceReachabilityScheduler {
    +void start()
    +void runOnce(ServiceReachabilityConfig cfg)
    +long triggerManualRun()
    ~{static} boolean internetConfirmedUp(List<Measurement> recent)
  }
}

' ============================================================
'  .measurement
' ============================================================
package "measurement" {
  interface Measurer <<interface>> {
    +Measurement measure(String target)
  }
  class Measurement {
    -Instant timestamp
    -String target
    -double latencyMs
    -boolean success
    -String type
    -String localIPv4
    -String hostHash
    -boolean excluded
    +boolean isSuccess()
    +String getType()
    +boolean isExcluded()
  }
  class PingMeasurer {
    +Measurement measure(String target)
    +Measurement measure(String target, String type)
  }
  class DnsMeasurer {
    +Measurement measure(String hostname)
  }
  class HttpMeasurer {
    -HttpClient client
    +Measurement measure(String url)
  }
  class DnsBenchmark {
    -List<DnsServer> dnsServers
    +List<DnsResult> benchmark()
  }
}

' ============================================================
'  .network
' ============================================================
package "network" {
  class GatewayDiscovery {
    +{static} List<String> discoverLocalChain()
    +{static} boolean runningInContainer()
    +{static} boolean isVirtualGatewayRange(String ip)
    +{static} boolean isDockerLikeRange(String ip)
    ~{static} List<String> extractLocalChain(List<String> hops)
    ~{static} List<String> stripVirtualLeadingHops(List<String> chain)
    ~{static} boolean isPrivateLan(String ip)
  }
  class NetworkInfo {
    +{static} String getLocalIPv4()
    +{static} String getExternalIPv4()
  }
  class HostIdentifier {
    +{static} String getHostHash()
    +{static} String getHostname()
    +{static} String getOperatingSystem()
  }
  class ServiceReachabilityProbe {
    +List<ServiceReachabilityResult> probeAll(ServiceReachabilityConfig cfg)
    +ServiceReachabilityResult probeOne(ServiceTarget t, boolean controlReachable, boolean useControlSni)
  }
  class ServiceReachabilityResult {
    -String serviceId
    -Verdict verdict
    -String method
    -int httpStatus
  }
}

' ============================================================
'  .storage  (Twin-DB + DTOs)
' ============================================================
package "storage" {
  class H2MeasurementRepository {
    -Connection primary
    -Connection shadow
    +void save(Measurement m)
    +List<Measurement> findLastN(int n)
    +List<Measurement> findSince(Instant since)
    +Statistics calculateStatistics(String type, int hours)
    +int excludeRange(Instant from, Instant to, boolean excluded)
    +List<IpChange> getIpChanges(int limit)
    +List<HostInfo> getAllHosts()
    -void writeOnBoth(ConnectionAction action)
  }
  class Statistics {
    -double avgLatency
    -double p95Latency
    -double packetLossPercent
    -double jitter
  }
  class HourlyAverage
  class HostInfo
  class IpChange
  class IpChangeStats
  class ServiceCheck {
    -Instant timestamp
    -String serviceId
    -String verdict
    -String method
  }
}

' ============================================================
'  .report  (Auswertung + Berichte)
' ============================================================
package "report" {
  class ReliabilityReport {
    +{static} ReliabilityReport compute(List<Measurement> ping, int interval, long windowSeconds, int maintenanceSamples)
    +double getUptimePercent()
    +double getCoveragePercent()
    +long getMtbfSeconds()
    +long getMttrSeconds()
    +List<Outage> getOutages()
  }
  class "ReliabilityReport.Outage" as Outage {
    -Instant start
    -Instant end
    -long durationSeconds
    -int sampleCount
    -boolean excluded
  }
  class ConnectivityAssessment {
    +{static} Verdict assess(Statistics near, Statistics far, Statistics net)
    +{static} boolean isHealthy(Statistics s)
  }
  class PdfReportGenerator {
    -H2MeasurementRepository repository
    +byte[] generateReport(int hours)
    -ReliabilityReport addReliabilitySection(...)
    -void addConnectivitySection(...)
    -void addReachabilitySection(...)
  }
  class ServiceReachabilityAssessment {
    +{static} Verdict classify(Observation o)
    +{static} boolean isBlocked(Verdict v)
    +{static} String verdictKey(Verdict v)
  }
  class ServiceReachabilityReport {
    +{static} ServiceReachabilityReport compute(String serviceId, List<ServiceCheck> checks)
    +List<Episode> getEpisodes()
    +double getReachablePercent()
  }
  class "ServiceReachabilityReport.Episode" as Episode {
    -String verdict
    -Instant start
    -Instant end
    -int sampleCount
  }
}

' ============================================================
'  .config  (Config schlank + je eigene Datei)
' ============================================================
package "config" {
  class Config <<Singleton>> {
    -{static} volatile Config instance
    -MeasurementConfig measurement
    -GatewayConfig gateway
    -ServiceReachabilityConfig serviceReachability
    -MaintenanceWindow maintenanceWindow
    +{static} Config load(String path)
    +{static} void save(String path)
    +{static} Config getInstance()
    +{static} String hashPassword(String password)
    +void updateGateway(...)
  }
  class MeasurementConfig {
    -int intervalSeconds
    -Targets targets
  }
  class Targets {
    -String ping
    -String dns
    -String http
  }
  class GatewayConfig {
    -boolean autoDiscover
    -String near
    -String far
    -boolean nearManual
    -boolean farManual
    -boolean nearPersistent
    -boolean farPersistent
    -boolean farPingEnabled
  }
  class MaintenanceWindow {
    -boolean enabled
    +boolean isMaintenanceTime()
  }
  class DnsServer
  class DatabaseConfig
  class WebserverConfig
  class UserInfo
  class AuthConfig
  class SetupConfig
  class PushConfig
  class ThemeConfig
  class ServiceReachabilityConfig {
    -boolean enabled
    -int intervalMinutes
    -boolean useControlSni
    -List<ServiceTarget> services
  }
  class ServiceTarget {
    -String id
    -String domain
    -ServiceKind kind
    -boolean enabled
  }
}

' ============================================================
'  .web  (Orchestrator + Auth)
' ============================================================
package "web" {
  class WebServer {
    -H2MeasurementRepository repository
    -SessionManager sessionManager
    -Javalin app
    +void start(int port)
    +void stop()
  }
  class SessionManager {
    +String createSession(String role)
    +Session getSession(String token)
  }
  class ErrorResponse {
    +String error
  }
}

' ============================================================
'  .web.view  (HTML-Renderer)
' ============================================================
package "web.view" {
  class HtmlPageRenderer {
    +String render()
  }
  class SetupPageRenderer {
    +String render()
  }
  class LoginPageRenderer {
    +String render()
  }
}

' ============================================================
'  .web.api  (Routen-Registrare, je static register(...))
' ============================================================
package "web.api" {
  class PageRoutes
  class MeasurementRoutes
  class ReliabilityRoutes
  class ExportRoutes
  class HostRoutes
  class DnsRoutes
  class SettingsRoutes
  class SetupRoutes
  class AuthRoutes
  class ServiceReachabilityRoutes
}

' ============================================================
'  .i18n  /  .notification
' ============================================================
package "i18n" {
  class I18n {
    +{static} void load(String code)
    +{static} String get(String key)
    +{static} String resolve(String html)
  }
}
package "notification" {
  class PushNotificationService <<Singleton>>
}

' --- Strategy-Pattern ---
Measurer <|.. PingMeasurer
Measurer <|.. DnsMeasurer
Measurer <|.. HttpMeasurer

' --- Messung ---
PingMeasurer --> Measurement : erzeugt
DnsMeasurer  --> Measurement : erzeugt
HttpMeasurer --> Measurement : erzeugt
Measurement  --> NetworkInfo : liest IPs
Measurement  --> HostIdentifier : liest Host-Hash
DnsBenchmark --> DnsServer : verwendet

' --- Repository ---
H2MeasurementRepository --> Measurement
H2MeasurementRepository --> Statistics
H2MeasurementRepository --> HourlyAverage
H2MeasurementRepository --> HostInfo
H2MeasurementRepository --> IpChange
H2MeasurementRepository --> IpChangeStats

' --- Auswertung ---
ReliabilityReport --> Outage
ReliabilityReport ..> Measurement
ConnectivityAssessment ..> Statistics
PdfReportGenerator --> H2MeasurementRepository
PdfReportGenerator --> ReliabilityReport
PdfReportGenerator --> ConnectivityAssessment

' --- Config ---
Config --> MeasurementConfig
MeasurementConfig --> Targets
Config --> GatewayConfig
Config --> MaintenanceWindow

' --- Web ---
WebServer --> SessionManager
WebServer --> HtmlPageRenderer
WebServer --> SetupPageRenderer
WebServer --> LoginPageRenderer
WebServer --> PageRoutes : register(app, ...)
WebServer --> MeasurementRoutes
WebServer --> ReliabilityRoutes
WebServer --> ExportRoutes
WebServer --> HostRoutes
WebServer --> DnsRoutes
WebServer --> SettingsRoutes
WebServer --> SetupRoutes
WebServer --> AuthRoutes
web.api ..> H2MeasurementRepository : Routen-Handler
web.api ..> ErrorResponse
HtmlPageRenderer ..> I18n
HtmlPageRenderer ..> Config : liest Theme/Gateway-Labels

' --- Discovery / Main ---
SignalReportApp --> Measurer
SignalReportApp --> GatewayDiscovery
SignalReportApp --> H2MeasurementRepository
SignalReportApp --> WebServer
SignalReportApp --> Config

' --- Dienst-Erreichbarkeit (V2) ---
SignalReportApp --> ServiceReachabilityScheduler
ServiceReachabilityScheduler --> ServiceReachabilityProbe
ServiceReachabilityProbe ..> ServiceReachabilityAssessment
ServiceReachabilityProbe --> ServiceReachabilityResult
ServiceReachabilityReport ..> ServiceCheck
ServiceReachabilityReport --> Episode
H2MeasurementRepository --> ServiceCheck
Config --> ServiceReachabilityConfig
ServiceReachabilityConfig --> ServiceTarget
WebServer --> ServiceReachabilityRoutes

note top of H2MeasurementRepository
  Embedded H2 (Twin-DB):
  Primary + Shadow, synchrones Schreiben (WRITE_DELAY=0).
  Lesen nur aus Primary. Auto-Recovery: korrupte DB
  wird beim Start aus der intakten rekonstruiert.
  Tabellen: measurements (+ Spalte excluded), hosts, ip_changes, service_checks
end note

note right of GatewayDiscovery
  Traceroute -> lokale Gateway-Kette (RFC 1918):
  nah = Router, fern = Internet-Gateway.
  Docker-Bridge (172.17/16) wird uebersprungen;
  VM/Container-NAT (10.0.2.x) -> "virtuell"-Warnung.
end note

note right of ReliabilityReport
  Luecken-bewusst: uptime = erfolgreiche/gemessene
  (nicht /Wanduhrzeit). Abdeckung, MTBF, MTTR.
  >=2 aufeinanderfolgende Fehlmessungen in einem
  zusammenhaengenden Lauf = EIN aggregierter Ausfall.
  Ausschluss aus der Wertung via Spalte "excluded".
end note

note bottom of WebServer
  Javalin-Orchestrator: Setup + 2 before-Filter
  (Setup-/Auth-Gating), delegiert die Routen an die
  10 Registrare im Paket web.api. Statische Assets
  (app.css/app.js) aus /web. Challenge-Response (SHA-256).
end note
@enduml
